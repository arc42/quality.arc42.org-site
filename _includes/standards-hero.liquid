{% assign standards_count = include.standards | size %}
{% assign standards_category_count = 0 %}
{% for category in include.category_order %}
  {% assign standards_in_category = include.standards | where_exp: "std", "std.categories contains category" %}
  {% if standards_in_category.size > 0 %}
    {% assign standards_category_count = standards_category_count | plus: 1 %}
  {% endif %}
{% endfor %}

{% capture standards_meta %}<b>{{ standards_count }}</b> standards across <b>{{ standards_category_count }}</b> categories.{% endcapture %}

{% include section-hero.liquid
  section="standards"
  title="Standards"
  lede="Authoritative references from ISO, IEEE, and others, grouped by category and linked to the qualities they back."
  meta=standards_meta %}

<nav class="standards-mode-switch" aria-label="Standards browsing modes">
  <a
    class="standards-mode-switch__link{% if include.active_mode == 'category' %} is-active{% endif %}"
    href="{{ include.category_href }}"
    {% if include.active_mode == 'category' %}aria-current="page"{% endif %}
  >
    <span class="standards-mode-switch__name">By category</span>
    <span class="standards-mode-switch__desc">Scan standards grouped by domain.</span>
  </a>
  <a
    class="standards-mode-switch__link{% if include.active_mode == 'explorer' %} is-active{% endif %}"
    href="{{ include.explorer_href }}"
    {% if include.active_mode == 'explorer' %}aria-current="page"{% endif %}
  >
    <span class="standards-mode-switch__name">By explorer</span>
    <span class="standards-mode-switch__desc">Search and filter across categories.</span>
  </a>
</nav>
