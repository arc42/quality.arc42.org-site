{% comment %} This file is "included" from each of the tag-efficient.md, tag-flexible.md etc files,
as these pages need to display all related requirements. {% endcomment %} {%- assign tag_to_find =
include.tag -%} {%- if tag_to_find and tag_to_find != "" -%}

{% assign filtered_requirements = "" | split: "" %}
{%- for item in site.requirements -%}
  {%- if item.tags contains tag_to_find -%}
    {% assign filtered_requirements = filtered_requirements | push: item %}
  {%- endif -%}
{%- endfor -%}

<div class="panel requirements-header" id="requirements">
  <h2>Requirements tagged with #{{ include.tag }}</h2>
</div>
<div id="search-results">
  {% if filtered_requirements.size > 0 %}
    <ul class="posts no-bullets">
      {%- for item in filtered_requirements -%}
        <li>
          <a class="reqs" href="{{item.permalink}}"
            >{% include icon.html name="target" size="xs" class="bullet" style="color: var(--req-text-color)" %} {{
            item.title }}</a
          >
        </li>
      {%- endfor -%}
    </ul>
  {% else %}
    <p>No requirements tagged with #{{ include.tag }} yet.</p>
  {% endif %}
</div>

{%- endif -%}
