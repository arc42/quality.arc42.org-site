{% comment %}
  standards-header — single-standard detail page header.

  Migrated to the unified section-hero component. The eyebrow "Standard"
  links back to /standards/ (replaces the old header-category-link).
  Standards taxonomy uses `categories` (not `tags`), rendered as chips.
{% endcomment %}
{% assign page = include.page %}

{% capture chips_html %}{% for category in page.categories %}<span class="category">#{{ category }}</span>{% endfor %}{% endcapture %}

{% include section-hero.liquid
  section="standards"
  title=page.title
  eyebrow_label="Standard"
  eyebrow_href="/standards/"
  chips_html=chips_html %}
