{% assign page = include.page %}

<header>
    <div class="panel quality-header">
        <h1>
            {% if include.link %}
            <a class="post-link" href="{{ page.url | prepend: site.baseurl }}">{{ page.title }}</a>
            {% else %}
            {{ page.title }}
            {% endif %}
        </h1>

        <div class="header-taxonomy-row">
            <ul class="tags">
                {% assign tags_num = (page.tags | size) %}
                {% if tags_num > 0 %}
                <li>{% include icon.html name="tags" style="color: var(--blue-text-color);" %}</li>
                {% endif %}
                {% for tag in page.tags %}
                <li>
                    <a class="tag" href="{{ '/tag-' | append: tag | prepend: site.baseurl }}">#{{ tag }}</a>
                </li>
                {% endfor %}
            </ul>

            {% unless include.show_category_link == false %}
            {% include header-category-link.liquid
              href='/qualities/'
              value='Characteristic'
              icon='network'
            %}
            {% endunless %}
        </div>

        <div class="clearfix">
        </div>
    </div>


</header>
