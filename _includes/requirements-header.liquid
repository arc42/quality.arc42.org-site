{% comment %}
  requirements-header — header for the requirements index/listing surfaces.

  Single-requirement detail pages use the bespoke header in
  _layouts/requirements.html (breadcrumb + h1 + Implements row); this
  include is consumed by _layouts/page_requirements.html and similar
  listing wrappers.

  Migrated to the unified section-hero component. The eyebrow
  "Requirement" links back to /requirements/, and tag chips render in the
  section-hero chips row.
{% endcomment %}
{% assign page = include.page %}

{% capture chips_html %}{% for tag in page.tags %}<a class="tag" href="{{ '/tag-' | append: tag | prepend: site.baseurl }}">#{{ tag }}</a>{% endfor %}{% endcapture %}

{% include section-hero.liquid
  section="requirements"
  title=page.title
  eyebrow_label="Requirement"
  eyebrow_href="/requirements/"
  chips_html=chips_html %}
