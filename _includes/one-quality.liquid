{% comment %}
This file is "included" from each of the tag-efficient.md, tag-flexible.md etc files,
as these pages need to display all related qualities/requirements.

{% endcomment %}

{%- assign tag_to_find = include.tag -%}
{%- if tag_to_find and tag_to_find != "" -%}

{% assign filtered_qualities = "" | split: "" %}
{%- for item in site.qualities -%}
  {%- if item.tags contains tag_to_find -%}
    {% assign filtered_qualities = filtered_qualities | push: item %}
  {%- endif -%}
{%- endfor -%}

<div class="panel quality-header">
  <h2>Qualities tagged with #{{ include.tag }}</h2>
</div>
<div id="search-results">
  {% if filtered_qualities.size > 0 %}
    <ul class="posts">
      {%- for item in filtered_qualities -%}
        <li> <a href="{{ item.url }}">{% include icon.html name="gem" size="xs" class="bullet" style="color: var(--quality-text-color);" %} {{ item.title }}</a></li>
      {%- endfor -%}
    </ul>
  {% else %}
    <p>No qualities tagged with #{{ include.tag }} yet.</p>
  {% endif %}
</div>

{%- endif -%}

 