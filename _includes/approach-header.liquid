{% assign page = include.page %}

<header>
    <div class="panel approaches-header">
        <h1>
            {% if include.link %}
            <a class="post-link" href="{{ page.url | prepend: site.baseurl }}">{{ page.title }}</a>
            {% else %}
            {% include icon.html name="puzzle" %} {{ page.title }}
            {% endif %}
        </h1>

        <div class="header-taxonomy-row">
            <ul class="tags">
                {% assign tags_num = (page.tags | size) %}
                {% if tags_num > 0 %}
                <li>{% include icon.html name="tags" style="color: var(--approaches-text-color);" %}</li>
                {% endif %}
                {% for tag in page.tags %}
                <li>
                    <a class="tag" href="{{ '/tag-' | append: tag | prepend: site.baseurl }}">#{{ tag }}</a>
                </li>
                {% endfor %}
            </ul>

            {% include header-category-link.liquid
              href='/approaches/'
              value='Approach'
              icon='network'
            %}
        </div>

        <div class="clearfix">
        </div>
    </div>
</header>
