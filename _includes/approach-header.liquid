{% comment %}
  approach-header — single-approach detail page header.

  Migrated to the unified section-hero component. The eyebrow "Approach"
  links back to /approaches/ (replaces the old header-category-link), and
  the tag chips render in the section-hero chips row.
{% endcomment %}
{% assign page = include.page %}

{% capture chips_html %}{% for tag in page.tags %}<a class="tag" href="{{ '/tag-' | append: tag | prepend: site.baseurl }}">#{{ tag }}</a>{% endfor %}{% endcapture %}

{% include section-hero.liquid
  section="approaches"
  title=page.title
  eyebrow_label="Approach"
  eyebrow_href="/approaches/"
  chips_html=chips_html %}
